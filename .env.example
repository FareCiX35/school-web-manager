NODE_ENV=production
PORT=3005
BASE_PATH=/
DATABASE_URL=postgresql://postgres:strong-password@127.0.0.1:5432/school_web_manager
SESSION_SECRET=replace-with-a-long-random-secret
# Optional when frontend and API are served on different origins.
# CORS_ORIGIN=https://example.com
# Optional override for frontend build output. Default is artifacts/school-website/dist/public
# FRONTEND_DIST=/app/artifacts/school-website/dist/public
